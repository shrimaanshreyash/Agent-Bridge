# ── AgentBridge Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Required: OpenRouter API key for LLM calls
# Get yours free at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Override the default LLM model (default: google/gemini-2.5-flash-lite)
# Any model from https://openrouter.ai/models works here.
# Recommended options:
#   google/gemini-2.5-flash-lite   — fast, cheap, great quality (default)
#   anthropic/claude-3-haiku  — very reliable JSON output
#   openai/gpt-4o-mini        — strong reasoning, slightly more expensive
# MODEL=google/gemini-2.5-flash-lite
